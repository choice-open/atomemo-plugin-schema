{
  "name": "@choiceopen/atomemo-plugin-schema",
  "version": "0.1.8",
  "description": "Schema for developing Choiceform atomemo plugins",
  "homepage": "https://github.com/choice-open/atomemo-plugin-schema#readme",
  "bugs": {
    "url": "https://github.com/choice-open/atomemo-plugin-schema/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/choice-open/atomemo-plugin-schema.git"
  },
  "license": "MIT",
  "author": "江志强 <zhiqiang.jiang@choiceform.com>",
  "type": "module",
  "exports": {
    "./schemas": {
      "development": "./src/schemas.ts",
      "default": "./dist/schemas.mjs"
    },
    "./types": {
      "development": "./src/types.ts",
      "default": "./dist/types.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "biome check --write",
    "dev": "tsdown --watch",
    "prepublishOnly": "bun run build --clean",
    "test": "bun test --dots",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "type-fest": "^5.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/bun": "^1.3.8",
    "bumpp": "^10.4.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      "./schemas": "./dist/schemas.mjs",
      "./types": "./dist/types.mjs",
      "./package.json": "./package.json"
    }
  }
}
